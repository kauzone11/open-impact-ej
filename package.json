{
  "name": "open-impact-ej",
  "version": "1.0.0",
  "private": false,
  "description": "Plataforma open source de gestão integrada para Empresas Juniores.",
  "repository": {
    "type": "git",
    "url": "https://github.com/kauzone11/open-impact-ej.git"
  },
  "bugs": {
    "url": "https://github.com/kauzone11/open-impact-ej/issues"
  },
  "homepage": "https://github.com/kauzone11/open-impact-ej#readme",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "tsx --test src/**/*.unit.test.ts",
    "test:integration": "tsx --test --test-concurrency=1 src/**/*.integration.test.ts",
    "test:e2e": "playwright test",
    "organization:bootstrap": "tsx scripts/bootstrap-organization.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "test:migrations": "tsx scripts/test-migrations.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "16.2.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.35.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.11",
    "prisma": "7.9.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "$sharp"
  }
}
