# PostgreSQL 16 connection used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/open_impact_ej

# Generate a unique random value with at least 32 characters.
AUTH_SECRET=replace-with-at-least-32-random-characters

# Canonical server and browser URLs. Use HTTPS in production.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secure invitation lifetime in hours (1 to 720).
INVITATION_TTL_HOURS=72

# Optional Resend adapter. Leave both empty to copy links manually.
RESEND_API_KEY=
INVITATION_EMAIL_FROM=

# Runtime mode.
NODE_ENV=development
